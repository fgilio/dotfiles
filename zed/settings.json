// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "languages": {
    "PHP": {
      // Intelephense is painfully slow and eats CPU/RAM. Disabling the language
      // server entirely (vs "language_servers": ["!intelephense"]) also stops Zed
      // from spinning up the extension's fallbacks (phpactor, phptools) instead.
      "enable_language_server": false
    }
  },
  "cli_default_open_behavior": "existing_window",
  "use_smartcase_search": false,
  "auto_update": false,
  // Reopen the previous session's windows on launch. This is Zed's default, but
  // pinned explicitly so an update that changes defaults can't silently disable it.
  "restore_on_startup": "last_session",
  // Autosave titled buffers ~1s after edits so an abrupt restart (update, crash,
  // OS reboot) can never lose written-to-disk work. NOTE: does not cover *untitled*
  // scratch buffers — give those a filename to make them update-proof.
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "agent_ui_font_size": 16.0,
  "git_panel": {
    "dock": "right",
  },
  "base_keymap": "Cursor",
  "collaboration_panel": {
    "dock": "right",
  },
  "outline_panel": {
    "dock": "right",
  },
  "project_panel": {
    "dock": "right",
  },
  "agent": {
    "dock": "left",
    "tool_permissions": {
      // "allow" auto-approved every agent action (terminal, file writes, MCP)
      // with only Zed's hardcoded blocklist as backstop, so prompt injection in
      // any file/page the agent reads became unconfirmed command execution.
      // This file is public and copied; keep the safe default.
      "default": "confirm",
    },
    "play_sound_when_agent_done": true,
    "default_model": {
      "provider": "anthropic",
      // claude-sonnet-4-latest is not a valid Anthropic alias; pin the real model
      "model": "claude-sonnet-4-6",
    },
  },
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato",
  },
  // Mirror of VSCode `search.useIgnoreFiles: false` — search git-ignored files too.
  "search": {
    "include_ignored": true,
  },
  // Port of VSCode `search.exclude`. NOTE: Zed has no search-only exclude, so these
  // also hide paths from the project tree + file finder (more aggressive than VSCode).
  // Specifying this key REPLACES Zed's defaults, so the defaults are re-listed first.
  "file_scan_exclusions": [
    // --- Zed defaults (must be re-declared since we override the key) ---
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    // --- vendor: hide everything except the "laravel" and "livewire" folders.
    // VSCode used {[^l],?[^ai]}*; globset uses [!x] negation, no `false` re-include,
    // so the brace alternation is split into two patterns.
    "**/vendor/[!l]*",
    "**/vendor/?[!ai]*",
    // --- public: hide everything except "index.php". Root-scoped (no **/) on purpose
    // so it only touches the app's root public/ and leaves docs/public/ visible.
    "public/[!i]*",
    "public/?[!n]*",
    // --- build output / dependencies ---
    "**/node_modules",
    "**/dist",
    "**/build",
    "**/.next",
    "**/.open-next",
    "**/.wrangler",
    "**/.docusaurus",
    // --- generated / IDE helper files ---
    "**/_ide_helper.php",
    "**/_ide_helper_models.php",
    "**/.phpstorm.meta.php",
    // --- lockfiles ---
    "**/composer.lock",
    "**/package-lock.json",
    // --- Laravel framework cache + tooling caches (**/ also matches at root) ---
    "**/storage/framework",
    "**/.phpunit.result.cache",
    "**/.phpunit.cache",
    "**/phpstan-baseline.neon",
  ],
}
