#!/usr/bin/env zsh
# Codex wrapper: secure mode (read-only sandbox, prompts for approval)
# -s read-only overrides config's danger-full-access

if [[ $# -eq 0 || "$1" == -* ]]; then
    # Interactive: no args, or flags (--resume, etc.)
    exec codex --search -s read-only --model gpt-5.6-sol --config model_reasoning_effort="high" "$@"
else
    # Non-interactive one-shot
    exec codex --search -s read-only --model gpt-5.6-sol --config model_reasoning_effort="high" exec --skip-git-repo-check "$@"
fi
