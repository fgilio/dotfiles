#!/usr/bin/env zsh
# Codex wrapper: secure mode (read-only sandbox, prompts for approval)
# -s read-only overrides config's danger-full-access

if [[ $# -eq 0 || "$1" == -* ]]; then
    # Interactive: no args, or flags (--resume, etc.). xhigh reasoning because
    # a long-lived session favors answer quality over latency
    exec codex --search -s read-only --model gpt-5.5 --config model_reasoning_effort="xhigh" "$@"
else
    # Non-interactive one-shot: medium reasoning, latency matters more here
    exec codex --search -s read-only --model gpt-5.5 --config model_reasoning_effort="medium" exec --skip-git-repo-check "$@"
fi
