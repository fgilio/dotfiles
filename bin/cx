#!/usr/bin/env zsh
# Codex wrapper: works in any shell context
# Sandbox config in ~/.codex/config.toml (sandbox_mode = "danger-full-access")

if [[ $# -eq 0 || "$1" == -* ]]; then
    # Interactive: no args, or flags (--resume, etc.)
    exec codex --search --dangerously-bypass-approvals-and-sandbox --model gpt-5.6-sol --config model_reasoning_effort="high" "$@"
else
    # Non-interactive one-shot: medium effort keeps one-offs fast
    exec codex --search --dangerously-bypass-approvals-and-sandbox --model gpt-5.6-sol --config model_reasoning_effort="medium" exec --skip-git-repo-check --ephemeral "$@"
fi
