#!/usr/bin/env bash
# Move files to Trash instead of permanently deleting
# Cross-volume: files on external drives are permanently deleted (real rm)
# Supports: -f (ignore missing), -v (verbose)
set -euo pipefail

REAL_RM="/bin/rm"
trash_dir="${TRASH_DIR:-$HOME/.Trash}"

# Debug mode: RM_DEBUG=1 trash file
[[ "${RM_DEBUG:-0}" == "1" ]] && set -x

get_device() {
  stat -f '%d' "$1" 2>/dev/null || echo ""
}

is_dangerous_path() {
  local p="$1"
  # Obvious dangerous raw forms, no forking needed
  case "$p" in
    / | . | .. | "" | ./ | ../ | /./* | /../*) return 0 ;; # dangerous
  esac
  # All-slash paths ("//") are root in disguise
  local stripped="${p%"${p##*[!/]}"}"
  [[ -z "$stripped" ]] && return 0 # dangerous
  # Resolve through the filesystem only when the final component is "." or ".."
  # (only those can normalize to /, e.g. "/usr/.."); skipping the resolution
  # for plain names is what keeps this script from forking per file
  local base="${stripped##*/}"
  if [[ "$base" == "." || "$base" == ".." ]]; then
    local resolved
    resolved="$(cd -- "$p" 2>/dev/null && pwd -P)" || resolved=""
    [[ "$resolved" == "/" ]] && return 0 # dangerous
  fi
  return 1 # safe
}

force=0
verbose=0

while getopts ":fv" opt; do
  case "$opt" in
    f) force=1 ;;
    v) verbose=1 ;;
    \?)
      echo "trash: illegal option -- $OPTARG" >&2
      exit 2
      ;;
  esac
done
shift $((OPTIND - 1))

[[ $# -eq 0 ]] && {
  echo "trash: missing operand" >&2
  exit 1
}

[[ -d "$trash_dir" ]] || mkdir -p -- "$trash_dir"
status=0
# Timestamp for deconflict names, computed only when a collision happens
ts=""
counter=0

trash_device="$(get_device "$trash_dir")"

for src in "$@"; do
  # Dangerous-path check before existence so `trash -f ''` fails loudly like
  # `rm -f ''` does; -f must only forgive missing files
  if is_dangerous_path "$src"; then
    echo "trash: refusing dangerous path: '$src'" >&2
    status=1
    continue
  fi

  if [[ ! -e "$src" && ! -L "$src" ]]; then
    [[ $force -eq 1 ]] && continue
    echo "trash: $src: No such file or directory" >&2
    status=1
    continue
  fi

  # External volume: use real rm (standard Unix behavior)
  src_device="$(get_device "$src")"
  if [[ -n "$trash_device" && -n "$src_device" && "$src_device" != "$trash_device" ]]; then
    [[ $verbose -eq 1 ]] && echo "trash: external volume, permanently deleting: $src" >&2
    if [[ -d "$src" && ! -L "$src" ]]; then
      "$REAL_RM" -rf -- "$src" || {
        echo "trash: failed to delete: $src" >&2
        status=1
      }
    else
      "$REAL_RM" -f -- "$src" || {
        echo "trash: failed to delete: $src" >&2
        status=1
      }
    fi
    continue
  fi

  # Same volume: move to Trash
  # Pure-bash basename: $(basename) forks add up across many files
  base="${src%"${src##*[!/]}"}"
  base="${base##*/}"
  dest="$trash_dir/$base"

  # Deconflict: timestamp.PID.counter
  if [[ -e "$dest" || -L "$dest" ]]; then
    [[ -n "$ts" ]] || ts="$(date +%Y%m%d-%H%M%S)"
    counter=$((counter + 1))
    dest="$trash_dir/$base.$ts.$$.$counter"
    # If still exists (unlikely), keep incrementing
    while [[ -e "$dest" || -L "$dest" ]]; do
      counter=$((counter + 1))
      dest="$trash_dir/$base.$ts.$$.$counter"
    done
  fi

  [[ $verbose -eq 1 ]] && printf 'trash: %s -> %s\n' "$src" "$dest" >&2
  command mv -- "$src" "$dest" || {
    echo "trash: failed: $src" >&2
    status=1
  }
done

exit $status
