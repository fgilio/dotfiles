#!/usr/bin/env zsh
# Gemini CLI wrapper: yolo mode (auto-approve, sandboxed)
# --yolo enables sandbox by default for safety

if [[ $# -eq 0 || "$1" == -* ]]; then
    # Interactive: no args, or flags (--resume, etc.), Gemini 3 Pro
    exec gemini --yolo -m gemini-3-pro-preview "$@"
else
    # Non-interactive: -p is what makes Gemini headless, Gemini 3 Flash
    exec gemini --yolo -m gemini-3-flash-preview -p "$@"
fi
