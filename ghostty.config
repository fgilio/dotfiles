# Ghostty Configuration

auto-update-channel = stable

# Theme (auto-switches with macOS appearance)
# theme = light:GitHub Light Default,dark:GitHub Dark
# theme = GitHub Dark
# theme = GitHub Light Default
# theme = Hyper
theme = light:Hyper Light,dark:Hyper

# Font
font-family = "JetBrains Mono"
font-size = 16
font-feature = -calt

adjust-cell-height = 15%

# Shell integration
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# Cursor
cursor-style = bar
cursor-style-blink = true
cursor-click-to-move = false

# Mouse
# selection-invert-fg-bg omitted so each theme's selection-background and
# selection-foreground apply (pink on light, eggplant on dark) instead of
# a low-contrast inversion of cell colors.
# minimum-contrast enforces WCAG AA (4.5:1) by auto-adjusting any fg/bg pair
# that falls below it, which fixes low-contrast selections over colored text.
minimum-contrast = 4.5
mouse-hide-while-typing = true
mouse-scroll-multiplier = 2

# Clipboard
copy-on-select = true
clipboard-paste-protection = true
clipboard-trim-trailing-spaces = true

# Splits
unfocused-split-opacity = 0.7

# Window
window-padding-balance = true
window-padding-x = 20
window-padding-y = 10
window-save-state = always
macos-titlebar-style = native

# Keybindings
keybind = shift+enter=text:\x1b\r
keybind = ctrl+alt+cmd+shift+1=set_font_size:13
keybind = ctrl+alt+cmd+shift+2=set_font_size:16

# macOS-style line editing (readline translations)
keybind = super+backspace=text:\x15
keybind = alt+backspace=text:\x17
keybind = ctrl+backspace=text:\x1bd

# Extra time to undo closing tabs/splits (default 5s)
undo-timeout = 20s
